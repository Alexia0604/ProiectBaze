<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <configSections>
    </configSections>
    <connectionStrings>
        <add name="BibliotecaElectronica.Properties.Settings.BibliotecaElectronicaConnectionString" connectionString="Data Source=Alexia;Initial Catalog=BibliotecaElectronica;Integrated Security=True;TrustServerCertificate=True" providerName="System.Data.SqlClient" />
